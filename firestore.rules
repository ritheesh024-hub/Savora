
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // UTILITY FUNCTIONS
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == "meruguritheesh09@gmail.com"
      );
    }
    function isStaff() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'cashier', 'kitchen'] || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.token.email == "meruguritheesh09@gmail.com");
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow unauthenticated lookup by employeeId for login if limited - strictly for MVP
      allow list: if true; 
      allow write: if isOwner(userId) || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.status == 'Cancelled');
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{id} {
      allow read: if true;
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount']);
      allow write: if isAdmin();
    }

    match /global_settings/config {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
