
{
  "entities": {
    "AdminProfile": {
      "title": "Admin Profile",
      "description": "Restricted administrative records. Primary Admin (sunnyritheesh@gmail.com) has exclusive access to platform-wide configuration.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "cashier", "kitchen"] },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "employeeId": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "disabled"] },
        "onlineStatus": { "type": "string", "enum": ["online", "offline", "busy"] },
        "stats": {
          "type": "object",
          "properties": {
            "ordersHandled": { "type": "number" },
            "billsGenerated": { "type": "number" },
            "kitchenUpdates": { "type": "number" }
          }
        }
      },
      "required": ["email", "role"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Customer and Staff profile for authenticated users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "photoUrl": { "type": "string" },
        "phone": { "type": "string" },
        "employeeId": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin", "cashier", "kitchen"] },
        "status": { "type": "string", "enum": ["active", "disabled"] },
        "address": { "type": "string" },
        "orderCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "Store-wide operational configuration.",
      "type": "object",
      "properties": {
        "isOpen": { "type": "boolean" },
        "deliveryActive": { "type": "boolean" },
        "storeName": { "type": "string" },
        "contactNumber": { "type": "string" },
        "deliveryCharge": { "type": "number" },
        "freeDeliveryThreshold": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/admins/{userId}": {
      "schema": "#/backend/entities/AdminProfile",
      "description": "Restricted collection for staff metadata"
    },
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Customer and staff profiles keyed by Firebase UID"
    },
    "/global_settings/config": {
      "schema": "#/backend/entities/GlobalSettings",
      "description": "Singleton configuration for the entire ecosystem"
    },
    "/orders/{orderId}": {
      "schema": "object",
      "description": "Collection of customer and store orders"
    },
    "/products/{productId}": {
      "schema": "object",
      "description": "Inventory management"
    }
  }
}
